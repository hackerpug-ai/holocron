{
  "name": "holocron",
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "clean:ios": "rm -rf ios/build && rm -rf ~/Library/Developer/Xcode/DerivedData/holocron-*",
    "web": "expo start --web",
    "lint": "eslint .",
    "client:dev": "defaults delete com.apple.iphonesimulator CurrentDeviceUDID 2>/dev/null; rm -rf .expo/prebuild 2>/dev/null; expo start --ios --clear",
    "server:dev": "npx convex dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:ios": "npx expo prebuild --clean && npx expo run:ios --device --configuration Release",
    "validate": "npx tsx scripts/validate-migration.ts",
    "storybook": "STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --clear",
    "storybook:ios": "STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --ios --clear",
    "storybook:android": "STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --android --clear",
    "benchmark-search": "npx tsx scripts/benchmark-search.ts"
  },
  "dependencies": {
