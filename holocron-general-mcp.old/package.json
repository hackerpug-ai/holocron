{
  "name": "@holocron/mcp-general",
  "version": "0.1.0",
  "description": "MCP server exposing Holocron general document operations (search, storage, retrieval)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "holocron-general-mcp": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "holocron",
    "document",
    "search",
    "storage"
  ],
  "author": "Justin Rich",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "convex": "^1.18.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
