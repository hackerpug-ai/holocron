{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.13.1",
      "env": {
        "APP_ENV": "development"
      },
      "channel": "development"
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "node": "22.13.1",
      "env": {
        "APP_ENV": "development"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "store",
      "node": "22.13.1",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.13.1",
      "channel": "production",
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "$EAS_ASC_APP_ID",
        "ascApiKeyPath": "$EAS_ASC_API_KEY_PATH",
        "ascApiKeyIssuerId": "$EAS_ASC_ISSUER_ID",
        "ascApiKeyId": "$EAS_ASC_KEY_ID",
        "appleTeamId": "$EAS_APPLE_TEAM_ID"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "$EAS_ASC_APP_ID",
        "ascApiKeyPath": "$EAS_ASC_API_KEY_PATH",
        "ascApiKeyIssuerId": "$EAS_ASC_ISSUER_ID",
        "ascApiKeyId": "$EAS_ASC_KEY_ID",
        "appleTeamId": "$EAS_APPLE_TEAM_ID"
      }
    }
  }
}
