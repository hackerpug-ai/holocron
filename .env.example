# Convex Backend
# Get this URL by running: npx convex dev
# Format: https://your-project-name.convex.cloud
EXPO_PUBLIC_CONVEX_URL="https://your-project.convex.cloud"

# AI Provider API Keys
# Supported providers: OpenAI, Z.ai (GLM), Cohere
# Get your API key from your provider's dashboard
EXPO_PUBLIC_LLM_API_KEY="your-api-key-here"

# Additional provider keys (optional - for multi-provider setups)
ZAI_API_KEY="your-zhipu-api-key"
COHERE_API_KEY="your-cohere-api-key"

# Langfuse (Optional - for AI observability and tracing)
# Sign up at: https://langfuse.com
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."

# Structured Logging
# Client (React Native)
EXPO_PUBLIC_LOGGING_ENABLED=true
EXPO_PUBLIC_LOG_LEVEL=info

ELEVENLABS_API_KEY="YOUR_KEY"

# YouTube Data API v3 - For transcript fetching
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY="AIzaSyD..."

# YouTube Service Account - For caption track downloads (RECOMMENDED)
# Service accounts don't require OAuth2 user interaction
# Setup: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download service account JSON key and set as Convex environment variable
# Command: npx convex env set GOOGLE_APPLICATION_CREDENTIALS_JSON '{"type":"service_account",...}'
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# YouTube OAuth2 - Alternative to service account (requires user interaction)
# Setup: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application)
# Redirect URI: http://localhost:3000/oauth/callback
YOUTUBE_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
YOUTUBE_OAUTH_CLIENT_SECRET="your-client-secret"
YOUTUBE_OAUTH_REFRESH_TOKEN="your-refresh-token"

# Jina Reader API - Fallback for YouTube transcripts
# Get your API key from: https://jina.ai/reader
JINA_API_KEY="jina_..."

# Expo Owner - For EAS builds and Expo projects
# Your Expo account username or organization
EXPO_OWNER="your-username-or-org"

# Apple App Store Connect (ASC) Credentials - For iOS app submission
# Get these from your Apple Developer account: https://appstoreconnect.apple.com
EAS_ASC_APP_ID="your-app-id"
EAS_ASC_KEY_PATH="./keys/AuthKey_XXXXXXXXXX.p8"
EAS_ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
EAS_ASC_KEY_ID="XXXXXXXXXX"
