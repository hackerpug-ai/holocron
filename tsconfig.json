{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "supabase/**/*",
    "holocron-mcp/**/*",
    "holocron-mcp.backup/**/*",
    "holocron-general-mcp.old/**/*",
    "scripts/**/*",
    "**/*.stories.tsx",
    ".rnstorybook/**/*"
  ]
}
